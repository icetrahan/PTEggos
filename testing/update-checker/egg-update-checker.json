{
    "meta": {
        "version": "PTDL_v2",
        "update_url": null
    },
    "exported_at": "2026-03-15T00:00:00+00:00",
    "name": "Isle Update Checker",
    "author": "ice@primalheaven.com",
    "description": "Self-contained update checker and binary patching pipeline. Downloads Linux and Windows vanilla binaries via SteamCMD, detects version changes, patches them locally with signature-based patch_worker.py, and uploads modded binaries to the backend for distribution. No external patching API needed.",
    "features": null,
    "docker_images": {
        "ghcr.io/icetrahan/testing:update-checker": "ghcr.io/icetrahan/testing:update-checker"
    },
    "file_denylist": [],
    "startup": "/bin/bash /entrypoint.sh",
    "config": {
        "files": "{}",
        "startup": "{\"done\": \"Update Checker Summary\"}",
        "logs": "{}",
        "stop": "^C"
    },
    "scripts": {
        "installation": {
            "script": "#!/bin/bash\necho done",
            "container": "alpine:3.4",
            "entrypoint": "ash"
        }
    },
    "variables": [
        {
            "name": "API Base URL",
            "description": "Base URL for the Primal Heaven backend API",
            "env_variable": "API_BASE_URL",
            "default_value": "https://api.primalheaven.com",
            "user_viewable": true,
            "user_editable": true,
            "rules": "required|string",
            "field_type": "text"
        },
        {
            "name": "API Direct URL",
            "description": "Direct backend URL for large binary uploads (bypasses Cloudflare 100MB limit)",
            "env_variable": "API_DIRECT_URL",
            "default_value": "http://172.93.100.254:25022",
            "user_viewable": true,
            "user_editable": true,
            "rules": "required|string",
            "field_type": "text"
        },
        {
            "name": "API Key",
            "description": "API key for authenticating with the backend",
            "env_variable": "API_KEY",
            "default_value": "",
            "user_viewable": true,
            "user_editable": true,
            "rules": "required|string",
            "field_type": "text"
        },
        {
            "name": "Steam App ID",
            "description": "The Isle Steam App ID",
            "env_variable": "SRCDS_APPID",
            "default_value": "1020410",
            "user_viewable": true,
            "user_editable": false,
            "rules": "required|string",
            "field_type": "text"
        },
        {
            "name": "Steam Beta Branch",
            "description": "Steam beta branch to download (e.g. evrima)",
            "env_variable": "STEAM_BETA",
            "default_value": "evrima",
            "user_viewable": true,
            "user_editable": true,
            "rules": "required|string",
            "field_type": "text"
        },
        {
            "name": "Steam User",
            "description": "Steam username for SteamCMD (anonymous for free games)",
            "env_variable": "STEAM_USER",
            "default_value": "anonymous",
            "user_viewable": true,
            "user_editable": true,
            "rules": "required|string",
            "field_type": "text"
        },
        {
            "name": "Steam Password",
            "description": "Steam password (leave empty for anonymous)",
            "env_variable": "STEAM_PASS",
            "default_value": "",
            "user_viewable": true,
            "user_editable": true,
            "rules": "nullable|string",
            "field_type": "text"
        }
    ]
}
